# ================================================================
#  WHALE TREND BOT — Ortam Değişkenleri
#  Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#      copy .env.example .env
# ================================================================

# ─────────────────────────────────────────────
# TELEGRAM
# ─────────────────────────────────────────────
# BotFather'dan alınan bot token'ı
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIjKlMnOpQrsTuVwXyZ

# Virgülle ayrılmış kanal/kullanıcı ID'leri
# Kanal: @kanaladi veya -100xxxxxxxxxx
# Kullanıcı: Telegram'da @userinfobot ile öğrenin
TELEGRAM_CHAT_IDS=@whaletrend_alerts,-100123456789

# ─────────────────────────────────────────────
# TWITTER / X SCRAPING
# ─────────────────────────────────────────────
# Backend seçimi: apify | rapidapi | mock
TWITTER_BACKEND=mock

# Apify (ücretsiz tier ~1000 tweet/ay)
# https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# RapidAPI Twitter Scraper (yedek)
# https://rapidapi.com/apigeek0/api/twitter-api45
RAPIDAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# ON-CHAIN APIs
# ─────────────────────────────────────────────
# Etherscan (ücretsiz: 5 req/s, 100k req/gün)
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# BscScan (ücretsiz tier)
# https://bscscan.com/myapikey
BSCSCAN_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Solscan (opsiyonel, Solana token'ları için)
SOLSCAN_API_KEY=

# ─────────────────────────────────────────────
# AYARLAR
# ─────────────────────────────────────────────
# Kaç dakikada bir tarama yapılsın (default: 5)
SCAN_INTERVAL_MINUTES=5

# Minimum whale işlem büyüklüğü (USD)
WHALE_THRESHOLD_USD=100000

# Log seviyesi: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Sentiment alert eşiği (0.0 - 1.0, default: 0.3)
SENTIMENT_THRESHOLD=0.3
